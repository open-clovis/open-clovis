BOT_NAME=clovis
CLAUDE_CODE_OAUTH_TOKEN="your-claude-oauth-token"
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
GITHUB_TOKEN=
# gogcli (Google Workspace CLI) — encrypts refresh tokens stored in data/workspace/.config/gogcli/
GOG_KEYRING_PASSWORD=
# Your Google account email — entrypoint warns when first-time OAuth is still needed
GOG_GOOGLE_ACCOUNT=
